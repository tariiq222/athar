{
  "name": "athar-backend",
  "version": "0.1.0",
  "description": "Athar backend — NestJS API for the content engine",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start:dev": "nest start --watch",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "roots": [
      "src"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.22",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "minio": "^8.0.7",
    "openai": "^6.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "satori": "^0.26.0",
    "sharp": "^0.35.2",
    "twitter-text": "^3.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^10.4.22",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/sharp": "^0.31.1",
    "@types/twitter-text": "^3.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-jest": "^29.15.3",
    "jest": "^30.4.2",
    "prettier": "^3.9.1",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
