PORT=3000
DATABASE_URL=postgresql://athar:athar@localhost:5442/athar?schema=public
REDIS_URL=redis://localhost:6389
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=athar
MINIO_SECRET_KEY=athar12345
MINIO_BUCKET=athar-images

# OpenRouter (single key for Claude + GPT-5-image + Gemini vision)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model ids (OpenRouter convention: provider/model)
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-5
OPENAI_IMAGE_MODEL=openai/gpt-5-image-mini
OPENAI_VISION_MODEL=google/gemini-3.1-flash-image
# Fallback names used by some env loaders (kept for clarity)
ANTHROPIC_FALLBACK_MODEL=anthropic/claude-haiku-4-5

# Phase 3 — Auth + Tenant (JWT, refresh-token rotation, trial + PDPL purge)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
TRIAL_DURATION_DAYS=7
PURGE_RETENTION_DAYS=30
