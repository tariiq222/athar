# Athar backend — environment configuration
# This file is validated at boot by src/config/config-validation.ts (Zod).
# The app will refuse to start if any required key is missing or invalid.
# Production adds stricter rules: SMTP_SECURE=true, MINIO_USE_SSL=true, MOYASAR_WEBHOOK_SECRET required.

# General
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (required)
DATABASE_URL=postgresql://athar:athar@localhost:5442/athar?schema=public

# Redis (required)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / object storage (required)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=athar
MINIO_SECRET_KEY=replace-me-with-32-or-more-chars
MINIO_BUCKET=athar-assets

# SMTP / email (required)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=athar
SMTP_PASS=replace-me
SMTP_SECURE=false

# JWT (required) — secrets MUST be at least 32 characters
JWT_ACCESS_SECRET=replace-me-with-at-least-32-characters-aaa
JWT_REFRESH_SECRET=replace-me-with-at-least-32-characters-bbb
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# AI providers (required)
OPENROUTER_API_KEY=sk-or-v1-replace-me
OPENAI_API_KEY=sk-replace-me

# LLM routing
LLM_REGION=any

# Image generation gate (Phase 1 engine)
IMAGE_GATE_PRIMARY_METHOD=overlay
IMAGE_GATE_MAX_ATTEMPTS=2

# Optional — extra trusted domains for the engine (comma-separated)
# ENGINE_TRUSTED_DOMAINS_EXTRA=

# Throttling
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=10

# Optional — error reporting
# SENTRY_DSN=

# Moyasar billing (Phase 6)
MOYASAR_PUBLISHABLE_KEY=pk_test_xxx
MOYASAR_SECRET_KEY=sk_test_xxx
# Required in production
MOYASAR_WEBHOOK_SECRET=replace-me
BILLING_PUBLIC_URL=https://app.example.com
SELLER_NAME=أثر
INVOICE_NUMBER_PREFIX=INV